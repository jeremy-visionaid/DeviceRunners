<Project>

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- Central Package Management -->
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    
    <!-- Artifacts Directory Configuration -->
    <UseArtifactsOutput>true</UseArtifactsOutput>
    <ArtifactsPath>$(MSBuildThisFileDirectory)artifacts</ArtifactsPath>

    <!-- Skip Xcode version validation so minor Xcode updates don't break builds -->
    <ValidateXcodeVersion>false</ValidateXcodeVersion>

    <!-- Treat all warnings as errors -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>

    <!-- .NET 11 preview SDK flags net9.0 workloads as EOL -->
    <CheckEolWorkloads>false</CheckEolWorkloads>
    <CheckEolTargetFramework>false</CheckEolTargetFramework>

    <!-- Avoid Editor binding warnings by using XAML source generation -->
    <MauiXamlInflator>SourceGen</MauiXamlInflator>
  </PropertyGroup>

</Project>